# ── Database ──────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=equisense
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/equisense

# ── Data APIs ─────────────────────────────────────────────
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here
FINNHUB_API_KEY=your_finnhub_key_here
NEWS_API_KEY=your_news_api_key_here

# ── Backend ───────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DEBUG=true
SECRET_KEY=change_this_in_production

# ── Frontend ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ── ML ────────────────────────────────────────────────────
MODEL_DIR=data/models
RANDOM_SEED=42
# FinBERT sentiment ETL (inference only; GPU optional: auto | cpu | cuda)
FINBERT_MODEL_NAME=ProsusAI/finbert
FINBERT_DEVICE=auto
FINBERT_BATCH_SIZE=16

# ── Control plane (optional Postgres) ───────────────────────
EXPERIMENT_STORE_BACKEND=memory
JOB_STORE_BACKEND=file
JOB_QUEUE_BACKEND=memory
LIFECYCLE_STORE_BACKEND=memory
