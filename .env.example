# ── Database ──────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=equisense
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/equisense

# ── Data APIs ─────────────────────────────────────────────
# Stooq CSV (download_ohlcv_dataset.py --source stooq): https://stooq.com/q/d/?s=aapl.us&get_apikey
STOOQ_API_KEY=
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here
FINNHUB_API_KEY=your_finnhub_key_here
NEWS_API_KEY=your_news_api_key_here
# FinBERT для тональности в GET /stocks/.../news (первый ответ дольше — загрузка модели)
NEWS_FINBERT_ENABLED=true
# Смок-тест (из каталога backend): uv run python scripts/verify_api_keys.py
BACKTEST_ALLOW_NETWORK_FALLBACK=false
AUTO_PROMOTION_MIN_ROC_AUC_DELTA=0.005
AUTO_PROMOTION_MAX_BRIER_INCREASE=0.01
AUTO_PROMOTION_MIN_F1_DELTA=-0.02

# ── Backend ───────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DEBUG=true
# Deploy: bump or inject at build (shown in GET /health and /api/v1/)
APP_VERSION=0.1.0
SECRET_KEY=change_this_in_production

# ── Frontend ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ── ML ────────────────────────────────────────────────────
MODEL_DIR=data/models
RANDOM_SEED=42
# Training split: train [0, train_frac), val [train_frac, val_end), test [val_end, 1)
TRAINING_SPLIT_TRAIN_FRACTION=0.70
TRAINING_SPLIT_VAL_END_FRACTION=0.85
TRAINING_MIN_ROWS=60
TRAINING_CALIBRATION_MIN_VAL_SAMPLES=50
# FinBERT sentiment ETL (inference only; GPU optional: auto | cpu | cuda)
FINBERT_MODEL_NAME=ProsusAI/finbert
FINBERT_DEVICE=auto
FINBERT_BATCH_SIZE=16

# ── Control plane (optional Postgres) ───────────────────────
EXPERIMENT_STORE_BACKEND=memory
JOB_STORE_BACKEND=file
JOB_QUEUE_BACKEND=memory
LIFECYCLE_STORE_BACKEND=memory
